-- ───────────────────────────────────────────────────────────────────────
-- 9. ACTUALIZAR MEDIAS DE VALORACIONES
-- ───────────────────────────────────────────────────────────────────────
UPDATE restaurantes SET media_valoraciones =
  (SELECT AVG(CAST(puntuacion AS REAL)) FROM valoraciones WHERE restaurante_id = restaurantes.id)
WHERE EXISTS (SELECT 1 FROM valoraciones WHERE restaurante_id = restaurantes.id);

